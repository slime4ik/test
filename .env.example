# --- Django ---
SECRET_KEY=replace_me_with_openssl_rand_hex_32
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com
CSRF_TRUSTED_ORIGINS=https://fun1.fun,https://www.fun1.fun
CORS_ALLOWED_ORIGINS=https://example.com

# --- Static / media (внутри контейнера) ---
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# --- Database (читает Django через DATABASE_URL) ---
DATABASE_URL=postgres://appuser:apppass@db:5432/appdb
# --- Database (читает контейнер postgres, отдельные переменные) ---
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=appdb

# --- Redis ---
REDIS_URL=redis://redis:6379/0
